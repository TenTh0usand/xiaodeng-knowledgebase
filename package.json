{
  "name": "xiaodeng-knowledge-base",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "dev:portal": "corepack pnpm --filter @xiaodeng/portal dev",
    "dev:life": "corepack pnpm --filter @xiaodeng/life docs:dev",
    "dev:work": "corepack pnpm --filter @xiaodeng/work docs:dev",
    "dev:fun": "corepack pnpm --filter @xiaodeng/fun docs:dev",
    "dev:leisure": "corepack pnpm --filter @xiaodeng/leisure docs:dev",
    "build:portal": "corepack pnpm --filter @xiaodeng/portal build",
    "build:life": "corepack pnpm --filter @xiaodeng/life docs:build",
    "build:work": "corepack pnpm --filter @xiaodeng/work docs:build",
    "build:fun": "corepack pnpm --filter @xiaodeng/fun docs:build",
    "build:leisure": "corepack pnpm --filter @xiaodeng/leisure docs:build",
    "build:sites": "corepack pnpm run build:portal && corepack pnpm run build:life && corepack pnpm run build:work && corepack pnpm run build:fun && corepack pnpm run build:leisure",
    "build": "corepack pnpm run build:sites && node ./scripts/assemble.mjs",
    "preview": "vite preview --outDir ./.output --host 0.0.0.0",
    "deploy:cloudflare": "corepack pnpm run build && wrangler pages deploy .output --project-name xiaodeng-knowledgebase --branch main"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "fs-extra": "^11.3.0",
    "vite": "^7.1.10",
    "vite-plugin-pages-sitemap": "^1.7.1",
    "vitepress": "^1.6.3",
    "vue": "^3.5.13"
  }
}
